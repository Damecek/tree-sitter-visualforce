{
  "name": "tree-sitter-visualforce",
  "version": "0.1.0",
  "description": "Visualforce grammar for Tree-sitter",
  "repository": "https://github.com/Damecek/tree-sitter-visualforce",
  "license": "MIT",
  "author": "Adam Stepanek",
  "main": "bindings/node",
  "types": "bindings/node",
  "keywords": [
    "incremental",
    "parsing",
    "salesforce",
    "tree-sitter",
    "visualforce"
  ],
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "bindings/**",
    "queries/**",
    "src/**"
  ],
  "dependencies": {
    "node-addon-api": "8.9.0",
    "node-gyp-build": "4.8.4"
  },
  "devDependencies": {
    "eslint": "9.14.0",
    "eslint-config-treesitter": "1.0.2",
    "prettier": "3.9.5",
    "tree-sitter-cli": "0.26.10",
    "tree-sitter-html": "0.23.2"
  },
  "peerDependencies": {
    "tree-sitter": "0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "scripts": {
    "build:native": "mkdir -p .build && tree-sitter build -o .build/visualforce.dylib",
    "build:wasm": "mkdir -p .build && tree-sitter build --wasm -o .build/tree-sitter-visualforce.wasm",
    "check:fixtures": "bash scripts/check-fixtures.sh",
    "check:metadata": "node scripts/check-metadata.mjs",
    "check:queries": "bash scripts/check-queries.sh",
    "check:regenerate": "tree-sitter generate --abi 15 && git diff --exit-code -- grammar.js src bindings tree-sitter.json",
    "format:check": "prettier --check grammar.js package.json tree-sitter.json eslint.config.mjs scripts/check-metadata.mjs .prettierrc.json .github/workflows/ci.yml",
    "generate": "tree-sitter generate --abi 15",
    "lint": "eslint grammar.js scripts/check-metadata.mjs",
    "test": "npm run test:corpus && npm run check:fixtures && npm run check:queries && npm run lint && npm run format:check && npm run check:metadata",
    "test:binding": "cargo test",
    "test:corpus": "tree-sitter test",
    "test:e2e": "bash scripts/e2e-clean-clone.sh"
  }
}
