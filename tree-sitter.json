{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "visualforce",
      "camelcase": "Visualforce",
      "title": "Visualforce",
      "scope": "source.visualforce",
      "path": ".",
      "external-files": ["src/tag.h"],
      "file-types": ["component", "page"],
      "injection-regex": "^visualforce$",
      "class-name": "TreeSitterVisualforce",
      "highlights": "queries/highlights.scm",
      "injections": "queries/injections.scm",
      "indents": "queries/indents.scm"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Salesforce Visualforce grammar for Tree-sitter",
    "authors": [
      {
        "name": "Adam Stepanek",
        "email": "Damecek@users.noreply.github.com",
        "url": "https://github.com/Damecek"
      }
    ],
    "links": {
      "repository": "https://github.com/Damecek/tree-sitter-visualforce",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "java": false,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
